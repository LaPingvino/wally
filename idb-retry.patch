+            {canWriteIssues && (
+              <Button ref={editTriggerRef} size="300" variant="Primary" onClick={() => openEdit('new')} aria-label="Create new issue" aria-keyshortcuts="n">
+                <Icon src={Icons.Plus} size="100" aria-hidden="true" /><Text>New Issue</Text>
