+                  renderFallback={() => <Icon size="50" src={Icons.User} filled />}
+                />
+              </Avatar>
+              <Text as="span" size="B400" priority="300" truncate>
+                {getName}
+              </Text>
+            </Box>
+          </Box>
+        </NavItemContent>
+      </NavButton>
+    </NavItem>
+  );
+}
