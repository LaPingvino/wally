+        const pats = String(content[f.key] ?? '').split(',').map((p) => p.trim()).filter(Boolean);
+        return pats.length > 0 ? <FollowActivity key={f.key} label={f.label} room={room} patterns={pats} /> : null;
+      })}
+    </Box>
+  );
+}
