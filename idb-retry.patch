+    if (!kanbanField) return null;
+
+    const order = getKanbanOrder(kanbanFieldKey);
+    const applyOrder = (entries: IssueEntry[], colKey: string): IssueEntry[] => {
+      const ids = order[colKey];
+      if (!ids?.length) return entries;
+      const pos = new Map(ids.map((id, i) => [id, i]));
