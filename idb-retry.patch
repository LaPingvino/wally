+    // eslint-disable-next-line no-restricted-syntax
+    for (const eventType of sendRecvToDevice) {
+      this.allowedCapabilities.add(
+        WidgetEventCapability.forToDeviceEvent(EventDirection.Send, eventType).raw
+      );
+      this.allowedCapabilities.add(
