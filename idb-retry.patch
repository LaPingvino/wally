+    room.on(RoomStateEvent.Members, onMember);
+    return () => {
+      cancelled = true;
+      if (rafId !== null) cancelAnimationFrame(rafId);
+      room.off(RoomStateEvent.Members, onMember);
+    };
+  }, [room, dm]);
 
   return name;
 };
