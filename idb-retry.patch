+      )}
+      <Box gap="200" style={{ flexWrap: 'wrap', padding: '0 ' + config.space.S300 }}>
+        <Box gap="100" alignItems="Center">
+          <Text size="T200" priority="300">Created by</Text>
+          <Text size="T200"><MemberDisplay room={room} userId={creatorId} /></Text>
+        </Box>
+        {lastChangedById !== creatorId && (
+          <Box gap="100" alignItems="Center">
+            <Text size="T200" priority="300">Last changed by</Text>
+            <Text size="T200"><MemberDisplay room={room} userId={lastChangedById} /></Text>
+          </Box>
+        )}
+      </Box>
+      <IssueActivity room={room} issueId={entry.event.getStateKey()!} defaultFolded />
+      {schema.fields.filter((f) => f.type === 'follow').map((f) => {
