+
+  return (
+    <section ref={ref as React.RefObject<HTMLElement>} aria-labelledby={colHeadingId}
+      style={{ minWidth: '240px', maxWidth: '320px', flexShrink: 0,
+        background: isOver ? color.Primary.Container : color.SurfaceVariant.Container,
+        outline: isOver ? '2px solid ' + color.Primary.Main : undefined,
+        borderRadius: config.radii.R300, padding: config.space.S300,
+        display: 'flex', flexDirection: 'column', gap: config.space.S200,
+        transition: 'background 0.15s' }}>
+      <Box alignItems="Center" style={{ justifyContent: 'space-between' }}>
+        <Text id={colHeadingId} as="h3" size="H6">{label.replace(/_/g, ' ')}</Text>
+        <Box alignItems="Center" gap="100">
+          <Text size="T200" priority="300" aria-label={entryCount + ' issues'}>{entryCount}</Text>
+          <button type="button" aria-label={'Hide ' + label + ' column'} onClick={onHide}
+            style={{ background: 'transparent', border: 'none', cursor: 'pointer', padding: '2px 4px',
+              color: 'inherit', opacity: 0.5, fontSize: '0.9em', lineHeight: 1 }}>✕</button>
+        </Box>
+      </Box>
+      {children}
