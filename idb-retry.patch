+            <>
+              <Text size="T200">Group by:</Text>
+              <select
+                value={effectiveViewMode.fieldKey}
+                onChange={(e) => switchView({ type: 'kanban', fieldKey: e.target.value })}
+                aria-label="Kanban grouping field"
+                style={inlineSelectStyle}>
+                {enumFields.map((f) => (
+                  <option key={f.key} value={f.key}>{f.label}</option>
+                ))}
+              </select>
+            </>
+          )}
+          {hiddenColumns.size > 0 && (() => {
+            const kanbanField = effectiveViewMode.type === 'kanban'
+              ? schema.fields.find((f) => f.key === effectiveViewMode.fieldKey)
+              : undefined;
+            const allCols = [
+              ...(kanbanField?.values ?? []).map((v) => ({ key: v, label: v })),
+              { key: '__uncategorized__', label: 'Uncategorized' },
+            ];
+            return allCols
+              .filter((col) => hiddenColumns.has(col.key))
+              .map((col) => (
+                <Button key={col.key} size="300" variant="Secondary" fill="Soft"
+                  onClick={() => setHiddenColumns((prev) => { const next = new Set(prev); next.delete(col.key); return next; })}
