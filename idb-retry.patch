+                </Tooltip>
+              }
+            >
+              {(triggerRef) => (
+                <IconButton fill="None" size="300" ref={triggerRef} aria-label={lkCtx.isCamEnabled ? 'Turn off camera' : 'Turn on camera'} onClick={() => { lkCtx.toggleCamera(); announce(lkCtx.isCamEnabled ? 'Camera off' : 'Camera on'); }}>
