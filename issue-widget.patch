+type FieldType = 'text' | 'enum' | 'user' | 'date' | 'follow';
+
+interface SchemaField {
+  key: string;
+  type: FieldType;
+  label: string;
+  required?: boolean;
+  values?: string[];
+  kanban_group?: boolean;
+}
+
+interface IssueSchema {
