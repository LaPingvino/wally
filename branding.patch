+  public async validateCapabilities(requested: Set<Capability>): Promise<Set<Capability>> {
+    const granted = new Set(requested);
+    // Only grant delayed-event capabilities when the server actually supports them.
+    // If the server doesn't support MSC4157/MSC4140, EC falls back to regular state events
+    // for membership at capability-grant time (the correct fallback level). Granting these
+    // on a server with broken support causes EC's MembershipManager to retry updateDelayedEvent
+    // 10 times then throw "Connection lost", crashing the call.
+    const supportsDelayed = await this.checkDelayedEventSupport();
+    if (!supportsDelayed) {
+      granted.delete(MatrixCapabilities.MSC4157SendDelayedEvent);
+      granted.delete(MatrixCapabilities.MSC4157UpdateDelayedEvent);
+    }
+    return granted;
+  }
