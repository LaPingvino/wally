+    this.client.on(ClientEvent.Event, this.onEvent);
+    this.client.on(MatrixEventEvent.Decrypted, this.onEventDecrypted);
+    this.client.on(ClientEvent.ToDeviceEvent, this.onToDeviceEvent);
+    // NOTE: io.element.join is intentionally NOT handled here.
+    // CallProvider.tsx handles it (sets isActiveCallReady + replies once).
+    // Having a handler here too would cause a double-reply, potentially
+    // corrupting EC's widget-api state machine after the lobby join.
+
+    this.messaging.on(
+      `action:${WidgetApiFromWidgetAction.UpdateAlwaysOnScreen}`,
+      async (ev: CustomEvent<IStickyActionRequest>) => {
+        if (this.messaging?.hasCapability(MatrixCapabilities.AlwaysOnScreen)) {
+          ev.preventDefault();
+          if (ev.detail.data.value) {
+            // If the widget wants to become sticky we wait for the stickyPromise to resolve
+            if (this.stickyPromise) await this.stickyPromise();
+          }
+          // Always reply — not replying causes a 10-second timeout in EC (e.g. after the lobby
+          // sends UpdateAlwaysOnScreen(false) to release sticky mode).
