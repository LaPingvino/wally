+  const merged = await readMDirect(mx);
+  for (const { roomId, partnerUserId } of picks) {
+    const list = merged[partnerUserId] || [];
+    if (!list.includes(roomId)) list.push(roomId);
+    merged[partnerUserId] = list;
+  }
