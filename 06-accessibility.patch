diff --git a/src/app/hooks/useGlobalKeyboardShortcuts.ts b/src/app/hooks/useGlobalKeyboardShortcuts.ts
new file mode 100644
index 00000000..de62d0da
--- /dev/null
+++ b/src/app/hooks/useGlobalKeyboardShortcuts.ts
@@ -0,0 +1,133 @@
+import { useCallback, useMemo } from 'react';
+import { useNavigate } from 'react-router-dom';
+import { useSetAtom } from 'jotai';
+import { isKeyHotkey } from 'is-hotkey';
+import { useKeyDown } from './useKeyDown';
+import { stopPropagation } from '../utils/keyboard';
+import { keyboardShortcutsHelpAtom } from '../state/keyboardShortcutsHelp';
+import { searchModalAtom } from '../state/searchModal';
+import { getHomePath, getDirectPath, getInboxNotificationsPath } from '../pages/pathUtils';
+
+export interface KeyboardShortcut {
+  key: string;
+  description: string;
+  category: 'Navigation' | 'Search' | 'Actions' | 'Help';
+  action: () => void;
+}
+
+const focusSection = (selector: string) => {
+  const el = document.querySelector(selector) as HTMLElement | null;
+  el?.focus();
+};
+
+export const useGlobalKeyboardShortcuts = () => {
+  const navigate = useNavigate();
+  const setShortcutsHelp = useSetAtom(keyboardShortcutsHelpAtom);
+  const setSearchModal = useSetAtom(searchModalAtom);
+
+  const shortcuts = useMemo<KeyboardShortcut[]>(
+    () => [
+      {
+        key: 'mod+k',
+        description: 'Search',
+        category: 'Search',
+        action: () => setSearchModal(true),
+      },
+      {
+        key: 'alt+r',
+        description: 'Focus room list',
+        category: 'Navigation',
+        action: () => focusSection('#cinny-room-listbox'),
+      },
+      {
+        key: 'alt+t',
+        description: 'Focus message timeline',
+        category: 'Navigation',
+        action: () => focusSection('#cinny-timeline'),
+      },
+      {
+        key: 'alt+c',
+        description: 'Focus message composer',
+        category: 'Navigation',
+        action: () => focusSection('[data-slate-editor="true"]'),
+      },
+      {
+        key: 'alt+h',
+        description: 'Go to Home',
+        category: 'Navigation',
+        action: () => navigate(getHomePath()),
+      },
+      {
+        key: 'alt+d',
+        description: 'Go to Direct Messages',
+        category: 'Navigation',
+        action: () => navigate(getDirectPath()),
+      },
+      {
+        key: 'alt+i',
+        description: 'Go to Inbox',
+        category: 'Navigation',
+        action: () => navigate(getInboxNotificationsPath()),
+      },
+      {
+        key: 'mod+/',
+        description: 'Show keyboard shortcuts',
+        category: 'Help',
+        action: () => setShortcutsHelp(true),
+      },
+    ],
+    [navigate, setShortcutsHelp, setSearchModal]
+  );
+
+  const handleKeyDown = useCallback(
+    (evt: KeyboardEvent) => {
+      // Section focus shortcuts work even inside editable elements
+      if (isKeyHotkey('alt+r', evt)) {
+        evt.preventDefault();
+        focusSection('#cinny-room-listbox');
+        return;
+      }
+      if (isKeyHotkey('alt+t', evt)) {
+        evt.preventDefault();
+        focusSection('#cinny-timeline');
+        return;
+      }
+      if (isKeyHotkey('alt+c', evt)) {
+        evt.preventDefault();
+        focusSection('[data-slate-editor="true"]');
+        return;
+      }
+
+      // Navigation shortcuts that bypass editable-element guard
+      if (isKeyHotkey('alt+h', evt)) {
+        evt.preventDefault();
+        navigate(getHomePath());
+        return;
+      }
+      if (isKeyHotkey('alt+d', evt)) {
+        evt.preventDefault();
+        navigate(getDirectPath());
+        return;
+      }
+      if (isKeyHotkey('alt+i', evt)) {
+        evt.preventDefault();
+        navigate(getInboxNotificationsPath());
+        return;
+      }
+
+      // Other shortcuts only when not typing in an editable element
+      if (!stopPropagation(evt)) return;
+
+      const shortcut = shortcuts.find((s) => isKeyHotkey(s.key, evt));
+      if (shortcut) {
+        evt.preventDefault();
+        shortcut.action();
+      }
+    },
+    [navigate, shortcuts]
+  );
+
+  useKeyDown(window, handleKeyDown);
+
+  return { shortcuts };
+};
diff --git a/src/app/hooks/useRoomListKeyboard.ts b/src/app/hooks/useRoomListKeyboard.ts
new file mode 100644
index 00000000..82edcf6a
--- /dev/null
+++ b/src/app/hooks/useRoomListKeyboard.ts
@@ -0,0 +1,134 @@
+import { useCallback, useEffect, useState } from 'react';
+import { Virtualizer } from '@tanstack/react-virtual';
+import { isKeyHotkey } from 'is-hotkey';
+
+interface UseRoomListKeyboardOptions {
+  items: string[];
+  selectedRoomId: string | undefined;
+  virtualizer: Virtualizer<HTMLDivElement, Element>;
+  onNavigate: (roomId: string) => void;
+  enabled?: boolean;
+  getItemLabel?: (id: string) => string;
+}
+
+export const useRoomListKeyboard = ({
+  items,
+  selectedRoomId,
+  virtualizer,
+  onNavigate,
+  enabled = true,
+  getItemLabel,
+}: UseRoomListKeyboardOptions) => {
+  const [focusedIndex, setFocusedIndex] = useState<number>(-1);
+
+  useEffect(() => {
+    if (focusedIndex >= items.length) {
+      setFocusedIndex(items.length - 1);
+    }
+  }, [items.length, focusedIndex]);
+
+  // Called when the listbox div receives focus (e.g. via Tab)
+  const handleFocus = useCallback(() => {
+    if (focusedIndex < 0) {
+      const selectedIndex = selectedRoomId ? items.indexOf(selectedRoomId) : 0;
+      const idx = selectedIndex >= 0 ? selectedIndex : 0;
+      setFocusedIndex(idx);
+      virtualizer.scrollToIndex(idx, { align: 'auto' });
+    }
+  }, [focusedIndex, items, selectedRoomId, virtualizer]);
+
+  const handleKeyDown = useCallback(
+    (evt: React.KeyboardEvent<HTMLDivElement>) => {
+      if (!enabled) return;
+
+      if (isKeyHotkey('arrowdown', evt)) {
+        evt.preventDefault();
+        setFocusedIndex((prev) => {
+          const next = prev < 0 ? 0 : Math.min(prev + 1, items.length - 1);
+          virtualizer.scrollToIndex(next, { align: 'auto' });
+          return next;
+        });
+        return;
+      }
+
+      if (isKeyHotkey('arrowup', evt)) {
+        evt.preventDefault();
+        setFocusedIndex((prev) => {
+          const next = prev < 0 ? items.length - 1 : Math.max(prev - 1, 0);
+          virtualizer.scrollToIndex(next, { align: 'auto' });
+          return next;
+        });
+        return;
+      }
+
+      if (isKeyHotkey('home', evt)) {
+        evt.preventDefault();
+        setFocusedIndex(0);
+        virtualizer.scrollToIndex(0, { align: 'start' });
+        return;
+      }
+
+      if (isKeyHotkey('end', evt)) {
+        evt.preventDefault();
+        const lastIndex = items.length - 1;
+        setFocusedIndex(lastIndex);
+        virtualizer.scrollToIndex(lastIndex, { align: 'end' });
+        return;
+      }
+
+      if ((isKeyHotkey('enter', evt) || isKeyHotkey('space', evt)) && focusedIndex >= 0) {
+        // Let child buttons (e.g. phone icon) handle their own Enter/Space
+        if (evt.target !== evt.currentTarget) return;
+        evt.preventDefault();
+        const roomId = items[focusedIndex];
+        if (roomId) {
+          onNavigate(roomId);
+        }
+        return;
+      }
+
+      if (isKeyHotkey('pagedown', evt)) {
+        evt.preventDefault();
+        setFocusedIndex((prev) => {
+          const next = Math.min(prev + 10, items.length - 1);
+          virtualizer.scrollToIndex(next, { align: 'auto' });
+          return next;
+        });
+        return;
+      }
+
+      if (isKeyHotkey('pageup', evt)) {
+        evt.preventDefault();
+        setFocusedIndex((prev) => {
+          const next = Math.max(prev - 10, 0);
+          virtualizer.scrollToIndex(next, { align: 'auto' });
+          return next;
+        });
+        return;
+      }
+
+      // Type-ahead: single printable character jumps to first matching room name
+      if (evt.key.length === 1 && !evt.ctrlKey && !evt.altKey && !evt.metaKey && getItemLabel) {
+        evt.preventDefault();
+        const char = evt.key.toLowerCase();
+        const startIndex = focusedIndex >= 0 ? focusedIndex + 1 : 0;
+        for (let i = 0; i < items.length; i++) {
+          const idx = (startIndex + i) % items.length;
+          if (getItemLabel(items[idx]).toLowerCase().startsWith(char)) {
+            setFocusedIndex(idx);
+            virtualizer.scrollToIndex(idx, { align: 'auto' });
+            return;
+          }
+        }
+      }
+    },
+    [enabled, items, focusedIndex, virtualizer, onNavigate, getItemLabel]
+  );
+
+  return {
+    focusedIndex,
+    handleKeyDown,
+    handleFocus,
+    setFocusedIndex,
+  };
+};
