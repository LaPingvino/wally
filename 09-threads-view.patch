diff --git a/src/app/features/room/ThreadView.tsx b/src/app/features/room/ThreadView.tsx
new file mode 100644
index 00000000..bdfb71ae
--- /dev/null
+++ b/src/app/features/room/ThreadView.tsx
@@ -0,0 +1,277 @@
+/**
+ * ThreadView — renders a single Matrix thread using the same RoomTimeline + RoomInput
+ * infrastructure as the main room view.
+ *
+ * Layout:
+ *   ┌─ root event header ─────────────────────────────┐
+ *   │  <sender>: <message preview>                     │
+ *   └──────────────────────────────────────────────────┘
+ *   ┌─ RoomTimeline (thread replies) ─────────────────┐
+ *   │  (full message rendering, pagination, etc.)      │
+ *   └──────────────────────────────────────────────────┘
+ *   ┌─ RoomInput (sends thread replies) ──────────────┐
+ *   └──────────────────────────────────────────────────┘
+ */
+import React, { useRef, useState, useEffect } from 'react';
+import { Box, Text, config, toRem } from 'folds';
+import { Room, MatrixEvent, ThreadEvent } from 'matrix-js-sdk';
+import { useEditor } from '../../components/editor';
+import { RoomTimeline } from './RoomTimeline';
+import { RoomInput } from './RoomInput';
+import { Page } from '../../components/page';
+import { getMxIdLocalPart, mxcUrlToHttp } from '../../utils/matrix';
+import { getMemberDisplayName } from '../../utils/room';
+import { useMatrixClient } from '../../hooks/useMatrixClient';
+import { useMediaAuthentication } from '../../hooks/useMediaAuthentication';
+import { useSetting } from '../../state/hooks/settings';
+import { settingsAtom } from '../../state/settings';
+
+// ── Root event header ──────────────────────────────────────────────────────────
+
+function getEventBodyPreview(event: MatrixEvent): string {
+  const content = event.getContent();
+  const body: string = content.body ?? content.formatted_body ?? '';
+  // Strip reply-to block ("> <@user:server> message\n\n")
+  const stripped = body.replace(/^> .*\n+/gm, '').trim();
+  return stripped.length > 200 ? `${stripped.slice(0, 200)}…` : stripped;
+}
+
+type RootEventHeaderProps = {
+  room: Room;
+  rootEvent: MatrixEvent;
+};
+function RootEventHeader({ room, rootEvent }: RootEventHeaderProps) {
+  const mx = useMatrixClient();
+  const useAuthentication = useMediaAuthentication();
+  const [hour24Clock] = useSetting(settingsAtom, 'hour24Clock');
+
+  const senderId = rootEvent.getSender() ?? '';
+  const displayName =
+    getMemberDisplayName(room, senderId) ?? getMxIdLocalPart(senderId) ?? senderId;
+
+  const member = room.getMember(senderId);
+  const avatarMxc = member?.getMxcAvatarUrl();
+  const avatarUrl = avatarMxc
+    ? mxcUrlToHttp(mx, avatarMxc, useAuthentication, 28, 28, 'crop') ?? undefined
+    : undefined;
+
+  const preview = getEventBodyPreview(rootEvent);
+  const ts = rootEvent.getDate();
+  const timeStr = ts
+    ? ts.toLocaleTimeString([], {
+        hour: '2-digit',
+        minute: '2-digit',
+        hour12: !hour24Clock,
+      })
+    : '';
+
+  return (
+    <Box
+      direction="Row"
+      gap="200"
+      style={{
+        padding: `${config.space.S200} ${config.space.S300}`,
+        borderBottom: `1px solid var(--bg-surface-border)`,
+        flexShrink: 0,
+        background: 'var(--bg-surface-low)',
+      }}
+    >
+      {/* Avatar */}
+      <div
+        style={{
+          width: toRem(28),
+          height: toRem(28),
+          borderRadius: '50%',
+          background: 'var(--bg-secondary)',
+          flexShrink: 0,
+          overflow: 'hidden',
+          display: 'flex',
+          alignItems: 'center',
+          justifyContent: 'center',
+          marginTop: toRem(2),
+        }}
+      >
+        {avatarUrl ? (
+          <img
+            src={avatarUrl}
+            alt={displayName}
+            style={{ width: '100%', height: '100%', objectFit: 'cover' }}
+          />
+        ) : (
+          <Text size="T200">{displayName[0]?.toUpperCase() ?? '?'}</Text>
+        )}
+      </div>
+
+      {/* Content */}
+      <Box direction="Column" grow="Yes" style={{ minWidth: 0 }}>
+        <Box gap="200" alignItems="Baseline">
+          <Text size="T300" weight="Medium" truncate>
+            {displayName}
+          </Text>
+          {timeStr && (
+            <Text size="T200" priority="300">
+              {timeStr}
+            </Text>
+          )}
+        </Box>
+        <Text size="T300" priority="300" style={{ opacity: 0.8, wordBreak: 'break-word' }}>
+          {preview || <em>Message</em>}
+        </Text>
+      </Box>
+    </Box>
+  );
+}
+
+// ── ThreadView ─────────────────────────────────────────────────────────────────
+
+type ThreadViewProps = {
+  room: Room;
+  threadRootId: string;
+};
+
+export function ThreadView({ room, threadRootId }: ThreadViewProps) {
+  const inputRef = useRef<HTMLDivElement>(null);
+  const viewRef = useRef<HTMLDivElement>(null);
+  const editor = useEditor();
+
+  // Start as false — always go through useEffect to populate the thread timeline
+  // before rendering RoomTimeline.
+  //
+  // Key insight: Thread.hasServerSideSupport = FeatureSupport.None = 0 (falsy), so
+  // thread.initialEventsFetched = !0 = true from the moment a Thread object is created.
+  // updateThreadMetadata() therefore never fetches from the server, and the thread
+  // timeline stays empty. We must populate it from the main room timeline ourselves,
+  // because /sync always puts thread reply events there regardless of MSC3440 support.
+  const [threadReady, setThreadReady] = useState(false);
+
+  useEffect(() => {
+    let cleanup: (() => void) | undefined;
+
+    // Fill the thread timeline from the main room timeline for events that arrived
+    // before this Thread SDK object was created.
+    // thread.addEventToTimeline has a built-in duplicate check, so safe to call always.
+    const populateFromMainTimeline = (thread: any) => {
+      const existingIds = new Set<string>(
+        (thread.liveTimeline.getEvents() as MatrixEvent[]).map((e: MatrixEvent) => e.getId()!)
+      );
+      const mainEvents = room
+        .getUnfilteredTimelineSet()
+        .getLiveTimeline()
+        .getEvents() as MatrixEvent[];
+      const replies = mainEvents.filter((e: MatrixEvent) => {
+        if (e.isRedacted() || existingIds.has(e.getId()!)) return false;
+        const rel = e.getContent()?.['m.relates_to'];
+        return rel?.rel_type === 'm.thread' && rel?.event_id === thread.id;
+      });
+      if (replies.length > 0) thread.addEvents(replies, false);
+    };
+
+    const attachToThread = (thread: any) => {
+      // Always populate from main room timeline before rendering.
+      populateFromMainTimeline(thread);
+
+      if (thread.initialEventsFetched) {
+        // No server-side fetch pending (server has no thread support, or it
+        // already completed). Thread timeline is now populated — ready to render.
+        setThreadReady(true);
+        return;
+      }
+
+      // Server supports MSC3440 and is still fetching initial events.
+      // Wait for ThreadEvent.Update (or fall back after timeout).
+      let readyCalled = false;
+      const goReady = () => {
+        if (readyCalled) return;
+        readyCalled = true;
+
+        // If server pagination failed (initialEventsFetched still false after
+        // ThreadEvent.Update), force the flag and replay buffered events.
+        if (!thread.initialEventsFetched) {
+          thread.initialEventsFetched = true;
+          const pending = (thread as any).replayEvents;
+          if (Array.isArray(pending)) {
+            (thread as any).replayEvents = null;
+            thread.addEvents(pending, false);
+          }
+          populateFromMainTimeline(thread);
+        }
+
+        setThreadReady(true);
+      };
+
+      // updateThreadMetadata always emits ThreadEvent.Update after the attempt.
+      const handleUpdate = () => goReady();
+      thread.on(ThreadEvent.Update as any, handleUpdate);
+      const fallbackTimer = setTimeout(goReady, 500);
+
+      cleanup = () => {
+        thread.off(ThreadEvent.Update as any, handleUpdate);
+        clearTimeout(fallbackTimer);
+      };
+    };
+
+    const thread = room.getThread(threadRootId);
+    if (thread) {
+      attachToThread(thread);
+    } else {
+      // Thread SDK object not registered yet.  createThread() registers it and
+      // kicks off async initialization (updateThreadMetadata), which will
+      // eventually emit ThreadEvent.Update → goReady.
+      const rootEvt = room.findEventById(threadRootId) ?? undefined;
+      try {
+        const newThread = room.createThread(threadRootId, rootEvt, [], false);
+        attachToThread(newThread);
+      } catch (_) {
+        // createThread failed; fall back to waiting for ThreadEvent.New.
+        const handleNewThread = (newThread: any) => {
+          if (newThread.id !== threadRootId) return;
+          room.off(ThreadEvent.New as any, handleNewThread);
+          attachToThread(newThread);
+        };
+        room.on(ThreadEvent.New as any, handleNewThread);
+        cleanup = () => room.off(ThreadEvent.New as any, handleNewThread);
+      }
+    }
+
+    return () => cleanup?.();
+  }, [room, threadRootId]);
+
+  const rootEvent =
+    room.getThread(threadRootId)?.rootEvent ?? room.findEventById(threadRootId) ?? null;
+
+  if (!threadReady) {
+    return (
+      <Page>
+        <Box grow="Yes" justifyContent="Center" alignItems="Center">
+          <Text size="T300" priority="300">Loading thread…</Text>
+        </Box>
+      </Page>
+    );
+  }
+
+  return (
+    <Page ref={viewRef}>
+      {rootEvent && <RootEventHeader room={room} rootEvent={rootEvent} />}
+      <Box grow="Yes" direction="Column">
+        <RoomTimeline
+          room={room}
+          roomInputRef={inputRef}
+          editor={editor}
+          threadId={threadRootId}
+        />
+      </Box>
+      <Box shrink="No" direction="Column">
+        <div style={{ padding: `0 ${config.space.S400}` }}>
+          <RoomInput
+            room={room}
+            roomId={room.roomId}
+            threadId={threadRootId}
+            editor={editor}
+            fileDropContainerRef={viewRef}
+            ref={inputRef}
+          />
+        </div>
+      </Box>
+    </Page>
+  );
+}
