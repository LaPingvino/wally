+          return (
+            <SidebarItem key={slot} active={isActive}>
+              <SidebarItemTooltip tooltip={session.userId}>
+                {(ref) => (
+                  <SidebarAvatar
+                    as="button"
+                    ref={ref}
+                    onClick={() => switchToSlot(slot)}
+                    aria-label={`Account: ${session.userId}${isActive ? ' (active)' : ''}`}
+                    aria-pressed={isActive}
+                    aria-keyshortcuts={`Alt+Shift+${shortcutN}`}
