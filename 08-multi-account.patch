+const SECONDARY_SESSIONS_KEY = 'cinny_sessions';
+
+type SlottedSession = { slot: number; session: Session };
+
+export function getSecondarySessions(): SlottedSession[] {
+  try {
+    const raw = localStorage.getItem(SECONDARY_SESSIONS_KEY);
+    return raw ? JSON.parse(raw) : [];
+  } catch {
+    return [];
+  }
+}
+
+export function addSecondarySession(session: Session): number {
+  const sessions = getSecondarySessions();
+  const usedSlots = sessions.map((s) => s.slot);
+  let slot = 1;
+  while (usedSlots.includes(slot)) slot++;
+  sessions.push({ slot, session });
+  localStorage.setItem(SECONDARY_SESSIONS_KEY, JSON.stringify(sessions));
+  return slot;
+}
+
+export function removeSecondarySession(slot: number): void {
+  const sessions = getSecondarySessions().filter((s) => s.slot !== slot);
+  localStorage.setItem(SECONDARY_SESSIONS_KEY, JSON.stringify(sessions));
+}
+
+export function getSessionForSlot(slot: number): Session | undefined {
+  return getSecondarySessions().find((s) => s.slot === slot)?.session;
+}
