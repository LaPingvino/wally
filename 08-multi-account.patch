+                    <Icon size="100" src={Icons.User} filled={isActive} />
+                  </SidebarAvatar>
+                )}
+              </SidebarItemTooltip>
+            </SidebarItem>
+          );
+        })}
+        <SidebarItem>
+          <SidebarItemTooltip tooltip="Add Account">
+            {(ref) => (
+              <SidebarAvatar
+                as="button"
+                ref={ref}
+                onClick={() => setShowAddAccount(true)}
+                aria-label="Add account"
+              >
+                <Icon size="100" src={Icons.Plus} />
+              </SidebarAvatar>
+            )}
+          </SidebarItemTooltip>
+        </SidebarItem>
+      </SidebarStack>
+      <SidebarStackSeparator />
