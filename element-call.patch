+// Minimal Room mock
+function makeRoom(isVoice: boolean, memberCount: number): Room {
+  return {
+    isCallRoom: () => isVoice,
+    currentState: { getJoinedMemberCount: () => memberCount },
+  } as unknown as Room;
+}
